{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the app windows (main + shipper)",
  "windows": ["main", "shipper"],
  "permissions": [
    "core:default",
    "core:webview:allow-create-webview-window",
    "core:window:allow-set-focus",
    "opener:default",
    "opener:allow-reveal-item-in-dir",
    "dialog:default",
    "dialog:allow-open",
    "notification:default"
  ]
}
